{
  "_说明": "后台珠子 & 玉牌料子 & 设计图管理配置",
  "_版本": "3.0",

  "上传配置": {
    "支持的图片格式": ["png", "jpg", "jpeg", "webp"],
    "图片最大尺寸": "2MB",
    "图片建议尺寸": "500x500 像素",
    "支持的3D格式": ["obj", "gltf", "glb", "stl"],
    "3D模型最大尺寸": "10MB",
    "存储方式": "云开发存储（cloud://）或 CDN 直链"
  },

  "珠子数据模板": {
    "id": "string (uuid)",
    "name": "string (admin-chosen name, e.g. '羊脂白·凝脂', '烟紫·星月')",
    "category": "enum: 主珠 | 配饰 | 三通&吊坠 | 隔片 | 绳子",
    "colorGroup": "enum: 羊脂白 | 烟紫 | 藕粉 | 湖水绿 | 糖玉 | 青花 | 墨玉 | 碧玉 | 黄口 | 且末蓝",
    "colorHex": "#7B5B95",
    "imageUrl": "string (cloud storage URL for display photo)",
    "model3dUrl": "string (cloud storage URL for .glb / .obj / .stl)",
    "meaning": "string (寓意 text, admin-written, shown when user taps image)",
    "description": "string (longer description)",
    "material": "string (e.g. '和田玉青海料')",
    "origin": "string (e.g. '青海')",
    "stock": "integer",
    "sizes": [
      {
        "sizeLabel": "string (e.g. '6mm', '8.5mm')",
        "price": "number (CNY)",
        "weight": "number (grams)",
        "stock": "integer"
      }
    ]
  },

  "料子数据模板": {
    "id": "string (uuid)",
    "name": "string (e.g. '烟紫牌料')",
    "colorGroup": "string (e.g. '烟紫', one of 10 jade color categories)",
    "colorHex": "#7B5B95",
    "imageUrl": "string (cloud storage URL for material photo)",
    "lengthMm": "number (admin-set, 长 in mm, free-text input)",
    "widthMm": "number (admin-set, 宽 in mm, free-text input)",
    "heightMm": "number (admin-set, 高/厚 in mm, free-text input)",
    "shape": "enum: 方形 | 圆形 | 椭圆 | 随形",
    "material": "string (e.g. '和田玉青海料')",
    "origin": "string",
    "price": "number (CNY, base price before design)",
    "stock": "integer",
    "isActive": "boolean"
  },

  "设计图数据模板": {
    "id": "string (uuid)",
    "name": "string (e.g. '富春山居')",
    "category": "string (e.g. '山水' | '龙凤' | '花鸟', admin-extensible)",
    "imageUrl": "string (design pattern image)",
    "meaning": "string (寓意, one-line, e.g. '隐居山林，悠然自得')",
    "description": "string (设计解释, multi-line detailed explanation)",
    "suitableAudience": "string (适合人群, admin-written, e.g. '喜爱传统文化的收藏者、商务人士、寻求内心宁静的人')",
    "isActive": "boolean"
  },

  "首页配置模板": {
    "homeBannerImageUrl": "string",
    "homeBannerLink": "string (optional tap target)",
    "themeColor": "enum: 羊脂白 | 烟紫 | 藕粉 | 湖水绿 | 糖玉 | 青花 | 墨玉 | 碧玉 | 黄口 | 且末蓝",
    "logoIconType": "string (admin-chosen icon style)"
  },

  "尺寸自定义说明": {
    "珠子尺寸": "管理员可在后台为每种珠子自由添加尺寸，格式如 '6mm'、'8.5mm'，不限制尺寸数量，每个尺寸独立定价",
    "料子尺寸": "管理员为每块料子设置独立的 长x宽x高（mm）。前端使用自由文本输入框（三输入：长/宽/高-厚），不再是固定下拉列表。每个料子品类只有一份模板，具体尺寸由管理员按库存批次设置。"
  },

  "和田玉十大色系分类": [
