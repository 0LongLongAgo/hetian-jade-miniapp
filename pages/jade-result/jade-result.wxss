.page-wrap { padding: 0 24rpx; }
.r-name { font-size: 32rpx; font-weight: 600; color: #7b5b95; }
.preview-box {
  background: #fff; border-radius: 24rpx; padding: 24rpx;
  text-align: center; margin: 12rpx 0; min-height: 200rpx;
  box-shadow: 0 2rpx 16rpx rgba(107,75,133,0.06);
}
.p-frame {
  display: inline-block; border-radius: 20rpx; overflow: hidden;
  border: 6rpx solid #ddd; position: relative;
  box-shadow: 0 8rpx 32rpx rgba(107,75,133,0.12);
}
.p-img { max-width: 100%; max-height: 280rpx; display: block; }
.p-img-placeholder {
  width: 200rpx; height: 200rpx;
  display: flex; align-items: center; justify-content: center;
}
.p-img-emoji { font-size: 64rpx; opacity: 0.4; }
.p-overlay { position: absolute; inset: 0; opacity: 0.25; }
.p-label { font-weight: 600; display: block; margin-top: 16rpx; color: #3d2e4e; font-size: 28rpx; }
.p-meaning { font-size: 24rpx; color: #A898B8; display: block; margin-top: 6rpx; }
.p-size { font-size: 24rpx; color: #A898B8; display: block; margin-top: 4rpx; }
.empty-preview {
  background: #fff; border-radius: 24rpx; padding: 60rpx 24rpx;
  text-align: center; color: #C4B0D6;
}
.info-row { font-size: 26rpx; padding: 6rpx 0; color: #3d2e4e; }
.lbl { font-weight: 600; color: #7b5b95; }
