/* === 手链设计页 - 专业布局（Canvas 版）=== */

.page-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F2F9;
}

/* ===== 主区域 — 上半部分 45% ===== */
.main-area {
  flex: 0 0 45%;
  display: flex;
  flex-direction: row;
  min-height: 0;
  position: relative;
  overflow: hidden;
}

/* ===== 左侧工具栏 ===== */
.left-toolbar {
  width: 80rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  gap: 4rpx;
  border-right: 1rpx solid #E8DFF0;
  flex-shrink: 0;
  z-index: 2;
}

.tb-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 4rpx;
  border-radius: 12rpx;
  width: 64rpx;
  transition: all 0.15s;
  cursor: pointer;
}

.tb-item.active {
  background: #F6F2F9;
}

.tb-icon {
  font-size: 32rpx;
  display: block;
}

.tb-label {
  font-size: 18rpx;
  color: #A898B8;
  margin-top: 2rpx;
  display: block;
}

/* ===== 中间预览区 ===== */
.center-preview {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  background: #F6F2F9;
  min-width: 0;
  padding: 20rpx;
}

.bg-toggle {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #fff;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  z-index: 5;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  cursor: pointer;
}

.bg-icon { font-size: 24rpx; }
.bg-label { font-size: 20rpx; color: #A898B8; }

/* Canvas 手串渲染 */
.bracelet-canvas {
  width: 300px;
  height: 300px;
  background: transparent;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(107,75,133,0.08);
}

/* 长度不足提示 */
.length-warning {
  position: absolute;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #fff3e0;
  border: 1rpx solid #ffcc80;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #e65100;
  white-space: nowrap;
  z-index: 3;
}

/* 预览区操作按钮 */
.preview-actions {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  display: flex;
  gap: 8rpx;
  align-items: center;
  z-index: 3;
  flex-wrap: wrap;
  justify-content: flex-end;
  width: 100%;
  padding-right: 16rpx;
}

.pa-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #fff;
  padding: 10rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #A898B8;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  cursor: pointer;
  transition: all 0.2s;
}

.pa-btn:active {
  transform: scale(0.95);
}

.pa-btn.rotate {
  background: #8BAAAA;
  color: #fff;
  font-weight: 600;
}

.pa-btn.rotate.rotating {
  background: #6B9A9A;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.pa-btn.export {
  background: #D4A04A;
  color: #fff;
  font-weight: 600;
}

.pa-btn.finish {
  background: #7B5B95;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(155,123,181,0.3);
}

/* ===== 右侧信息栏 ===== */
.right-info {
  width: 100rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  padding: 16rpx 8rpx;
  gap: 12rpx;
  border-left: 1rpx solid #E8DFF0;
  flex-shrink: 0;
}

.ri-row {
  text-align: center;
}

.ri-label {
  font-size: 20rpx;
  color: #A898B8;
  display: block;
  margin-bottom: 2rpx;
}

.ri-val {
  font-size: 24rpx;
  color: #3D2E4E;
  font-weight: 500;
  display: block;
}

.ri-val.large {
  font-size: 28rpx;
  font-weight: 600;
}

.ri-val.price {
  color: #e65100;
  font-weight: 700;
  font-size: 28rpx;
}

/* ===== 底部物料区 — 下半部分 55% ===== */
.bottom-materials {
  flex: 1;
  background: #fff;
  border-top: 1rpx solid #E8DFF0;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

/* 顶部分类标签 */
.cat-tabs {
  display: flex;
  white-space: nowrap;
  padding: 14rpx 16rpx;
  border-bottom: 1rpx solid #EDE4F4;
  flex-shrink: 0;
}

.cat-tab {
  display: inline-block;
  flex-shrink: 0;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #A898B8;
  margin-right: 6rpx;
  transition: all 0.15s;
  cursor: pointer;
}

.cat-tab.active {
  color: #7B5B95;
  font-weight: 600;
  border-bottom: 4rpx solid #7B5B95;
}

.cat-tab.search-tab {
  padding: 8rpx 12rpx;
}

/* 物料内容：左色系 + 右网格 */
.mat-content {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-height: 0;
}

/* 左侧色系 */
.color-sidebar {
  width: 120rpx;
  background: #F6F2F9;
  padding: 12rpx 8rpx;
  flex-shrink: 0;
}

.cs-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 8rpx;
  border-radius: 10rpx;
  margin-bottom: 4rpx;
  transition: all 0.15s;
  cursor: pointer;
}

.cs-item.active {
  background: #fff;
}

.cs-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 1rpx solid rgba(0,0,0,0.08);
}

.cs-label {
  font-size: 22rpx;
  color: #5E3D7A;
}

/* 右侧物料网格 */
.mat-grid-scroll {
  flex: 1;
  padding: 12rpx;
}

.mat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.mat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 14rpx 8rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(107,75,133,0.05);
  border: 2rpx solid transparent;
  transition: all 0.15s;
  cursor: pointer;
}

.mat-card:active {
  transform: scale(0.95);
  border-color: #7B5B95;
}

.mc-img-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 8rpx;
}

.mc-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 2rpx solid rgba(0,0,0,0.05);
}

.mc-img-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.05);
}

.mc-size-tag {
  font-size: 18rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}

.mc-name {
  font-size: 24rpx;
  color: #3D2E4E;
  display: block;
  font-weight: 500;
}

.mc-price {
  font-size: 24rpx;
  color: #e65100;
  font-weight: 600;
  display: block;
  margin-top: 4rpx;
}

.mc-size-badge {
  display: inline-block;
  margin-top: 6rpx;
  background: #F6F2F9;
  color: #7B5B95;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.empty {
  text-align: center;
  padding: 40rpx 20rpx;
  color: #A898B8;
  font-size: 26rpx;
}