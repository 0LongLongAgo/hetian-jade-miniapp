<view class="page-root">

  <view class="main-area">
    <!-- 左侧工具栏 -->
    <view class="left-toolbar">
      <view class="tb-item {{activeTool === 'size' ? 'active' : ''}}" bindtap="tapTool" data-tool="size">
        <text class="tb-icon">📏</text><text class="tb-label">尺寸</text>
      </view>
      <view class="tb-item" bindtap="undoBead">
        <text class="tb-icon">↩️</text><text class="tb-label">撤销</text>
      </view>
      <view class="tb-item" bindtap="confirmDesign">
        <text class="tb-icon">✅</text><text class="tb-label">确认</text>
      </view>
      <view class="tb-item" bindtap="clearBeads">
        <text class="tb-icon">🗑️</text><text class="tb-label">清空</text>
      </view>
    </view>

    <!-- 中间预览区 — Canvas 渲染 -->
    <view class="center-preview" style="background:{{bgIndex % 3 === 0 ? '#F6F2F9' : (bgIndex % 3 === 1 ? '#FFFFFF' : '#F5F0EB')}}">
      <view class="bg-toggle" bindtap="toggleBg">
        <text class="bg-icon">🖼</text><text class="bg-label">背景</text>
      </view>

      <!-- Canvas 手串渲染 -->
      <canvas class="bracelet-canvas" id="braceletCanvas" type="2d" bindtouchstart="onCanvasTouchStart" bindtouchend="onCanvasTouchEnd"></canvas>

      <!-- 旋转和导出按钮 -->
      <view class="preview-actions" wx:if="{{beads.length > 0}}">
        <view class="pa-btn rotate" bindtap="onRotateClick" wx:if="{{!isRotating}}">
          <text>🔄 旋转</text>
        </view>
        <view class="pa-btn rotate rotating" wx:else>
          <text>⏳ 旋转中...</text>
        </view>
        <view class="pa-btn export" bindtap="onExport">
          <text>📸 导出</text>
        </view>
        <view class="pa-btn finish" bindtap="finishDesign">
          <text>完成设计 ✨</text>
        </view>
      </view>

      <!-- 长度不足 -->
      <view class="length-warning" wx:if="{{beads.length > 0 && totalLengthNum < braceletSizeNum}}">
        <text>⚠️ 长度不足，请继续添加珠子~</text>
      </view>
    </view>

    <!-- 右侧信息栏 -->
    <view class="right-info">
      <view class="ri-row"><text class="ri-label">绳子</text><text class="ri-val">透明</text></view>
      <view class="ri-row"><text class="ri-label">周长</text><text class="ri-val large">{{totalLengthNum}}cm</text></view>
      <view class="ri-row"><text class="ri-label">克重</text><text class="ri-val">{{totalWeight}}g</text></view>
      <view class="ri-row"><text class="ri-label">价格</text><text class="ri-val price">¥{{totalPrice}}</text></view>
    </view>
  </view>

  <!-- 底部物料区 -->
  <view class="bottom-materials">
    <scroll-view class="cat-tabs" scroll-x="true" enable-flex="true">
      <view class="cat-tab {{beadCategory === item ? 'active' : ''}}" wx:for="{{beadCategories}}" wx:key="*this" data-cat="{{item}}" bindtap="switchBeadCategory">{{item}}</view>
      <view class="cat-tab search-tab" bindtap="searchBeads"><text>🔍</text></view>
    </scroll-view>

    <view class="mat-content">
      <scroll-view class="color-sidebar" scroll-y="true">
        <view class="cs-item {{currentColorGroup === item.key ? 'active' : ''}}" wx:for="{{colorGroups}}" wx:key="key" data-key="{{item.key}}" bindtap="switchColorGroup">
          <view class="cs-dot" style="background:{{item.color}};"></view>
          <text class="cs-label">{{item.label}}</text>
        </view>
      </scroll-view>

      <scroll-view class="mat-grid-scroll" scroll-y="true">
        <view class="mat-grid">
          <view class="mat-card" wx:for="{{filteredMaterials}}" wx:key="id" data-bead="{{item}}" bindtap="onBeadClick">
            <view class="mc-img-wrap">
              <image wx:if="{{item.img}}" src="{{item.img}}" mode="aspectFill" class="mc-img-img"></image>
              <view wx:else class="mc-img" style="background:{{item.color}};"><text class="mc-size-tag">{{item.size}}</text></view>
            </view>
            <text class="mc-name">{{item.name}}</text>
            <text class="mc-price">¥{{item.priceText}}</text>
            <view class="mc-size-badge"><text>{{item.size}}</text></view>
          </view>
        </view>
        <view class="empty" wx:if="{{filteredMaterials.length === 0}}"><text>暂无该分类珠子</text></view>
      </scroll-view>
    </view>
  </view>
</view>

<name-modal visible="{{showNameModal}}" beadInfo="{{pendingBeadInfo}}" bind:confirm="onNameConfirm" bind:cancel="onNameCancel"></name-modal>