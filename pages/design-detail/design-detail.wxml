<view class="page-root" wx:if="{{design}}">

  <!-- 顶部导航 -->
  <view class="top-bar">
    <view class="back-btn" bindtap="onBack">
      <text class="back-icon">←</text>
      <text class="back-label">返回</text>
    </view>
  </view>

  <!-- Hero 大图区 -->
  <view class="hero-area">
    <image wx:if="{{design.img}}" src="{{design.img}}" mode="aspectFill" class="hero-img"></image>
    <view wx:else class="hero-placeholder">
      <text class="hero-emoji">{{categoryEmoji[category] || '🏔️'}}</text>
      <text class="hero-hint">后台上传设计图后此处显示预览</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <view class="tag-row">
    <view class="cat-tag">{{category}}</view>
  </view>

  <!-- 设计名称 -->
  <view class="title-row">
    <text class="design-title">{{design.name}}</text>
  </view>

  <!-- 设计解释 -->
  <view class="info-card">
    <view class="card-header">
      <text class="card-icon">📖</text>
      <text class="card-label">设计解释</text>
    </view>
    <text class="card-body">{{design.description || '暂无详细设计解释，后台管理员可补充'}}</text>
  </view>

  <!-- 寓意 -->
  <view class="info-card">
    <view class="card-header">
      <text class="card-icon">💎</text>
      <text class="card-label">寓意</text>
    </view>
    <text class="card-body">{{design.meaning || '暂无寓意说明'}}</text>
  </view>

  <!-- 适合人群 -->
  <view class="info-card">
    <view class="card-header">
      <text class="card-icon">👥</text>
      <text class="card-label">适合人群</text>
    </view>
    <text class="card-body">{{design.suitableAudience || '暂无适合人群说明'}}</text>
  </view>

  <!-- 底部 CTA -->
  <view class="bottom-cta">
    <button class="cta-btn" bindtap="onSelectDesign">选择「{{design.name}}」开始创作</button>
  </view>

</view>

<!-- 未找到设计 -->
<view class="page-root empty-page" wx:else>
  <text class="empty-text">未找到设计详情</text>
  <button class="btn" bindtap="onBack" style="margin-top:24rpx;">返回</button>
</view>
