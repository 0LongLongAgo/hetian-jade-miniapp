.page-root {
  display: flex; flex-direction: column; min-height: 100vh;
  background: #F6F2F9; padding-bottom: 140rpx;
}

/* 顶部导航 */
.top-bar {
  padding: 20rpx 24rpx;
}
.back-btn {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 10rpx 20rpx; background: #fff; border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(107,75,133,0.08);
}
.back-icon { font-size: 32rpx; color: #7B5B95; font-weight: 600; }
.back-label { font-size: 26rpx; color: #7B5B95; }

/* Hero 大图 */
.hero-area {
  margin: 0 24rpx; border-radius: 24rpx; overflow: hidden;
  background: #fff; box-shadow: 0 4rpx 20rpx rgba(107,75,133,0.08);
}
.hero-img {
  width: 100%; aspect-ratio: 4/3;
}
.hero-placeholder {
  width: 100%; aspect-ratio: 4/3;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: linear-gradient(135deg, #EDE4F4 0%, #F6F2F9 100%);
}
.hero-emoji { font-size: 80rpx; opacity: 0.5; }
.hero-hint { font-size: 22rpx; color: #A898B8; margin-top: 8rpx; }

/* 标签 */
.tag-row { padding: 20rpx 24rpx 8rpx; }
.cat-tag {
  display: inline-block; padding: 8rpx 24rpx;
  background: #7B5B95; color: #fff; border-radius: 40rpx;
  font-size: 24rpx; font-weight: 500;
}

/* 设计名称 */
.title-row { padding: 4rpx 24rpx 20rpx; }
.design-title {
  font-size: 40rpx; font-weight: 700; color: #3D2E4E;
}

/* 信息卡片 */
.info-card {
  margin: 0 24rpx 16rpx;
  background: #fff; border-radius: 20rpx;
  padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(107,75,133,0.05);
}
.card-header {
  display: flex; align-items: center; gap: 10rpx; margin-bottom: 16rpx;
}
.card-icon { font-size: 36rpx; }
.card-label {
  font-size: 28rpx; font-weight: 600; color: #3D2E4E;
}
.card-body {
  font-size: 26rpx; color: #5A4A6A; line-height: 1.8;
}

/* 底部 CTA */
.bottom-cta {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 24rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, #F6F2F9 30%);
}
.cta-btn {
  width: 100%; height: 96rpx;
  background: linear-gradient(135deg, #7B5B95 0%, #8B6BA5 100%);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 48rpx; border: none;
  box-shadow: 0 8rpx 24rpx rgba(123,91,149,0.3);
  display: flex; align-items: center; justify-content: center;
}
.cta-btn::after { border: none; }

/* 空状态 */
.empty-page {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 100vh;
}
.empty-text { font-size: 30rpx; color: #A898B8; }
