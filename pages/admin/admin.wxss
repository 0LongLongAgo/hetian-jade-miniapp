/* === 后台管理页 === */

.page-root {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* ===== 管理入口导航 ===== */
.admin-nav {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: var(--card);
  border-bottom: 1rpx solid var(--border);
}
.an-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 12rpx;
  border-radius: 16rpx;
  background: var(--purple-bg);
  transition: all 0.15s;
}
.an-card.active {
  background: var(--purple-accent);
}
.an-card.active .an-label {
  color: #fff;
}
.an-card:active {
  transform: scale(0.96);
}
.an-icon {
  font-size: 32rpx;
  display: block;
}
.an-label {
  font-size: 22rpx;
  color: var(--purple-dark);
  font-weight: 500;
  margin-top: 6rpx;
}

/* ===== 管理面板 ===== */
.admin-panel {
  flex: 1;
  padding: 16rpx 24rpx;
}

.panel-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.panel-hint {
  font-size: 22rpx;
  color: var(--purple-muted);
}
.panel-note {
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background: #FFF9E6;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #8B7A4A;
  line-height: 1.6;
}

/* ===== 数据列表项 ===== */
.data-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.dli-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--card);
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(94,61,122,0.04);
}
.dli-item:active {
  opacity: 0.85;
}
.dli-color {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(0,0,0,0.06);
}
.dli-img-wrap {
  width: 80rpx;
  height: 56rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.dli-img {
  width: 100%;
  height: 100%;
}
.dli-info {
  flex: 1;
  min-width: 0;
}
.dli-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}
.dli-meta {
  font-size: 22rpx;
  color: var(--purple-muted);
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.dli-action {
  font-size: 28rpx;
  padding: 8rpx 12rpx;
  flex-shrink: 0;
}
.dli-actions {
  display: flex;
  gap: 4rpx;
  flex-shrink: 0;
}

/* ===== 价格面板 ===== */
.pricing-panel .card {
  margin-bottom: 16rpx;
}
.pri-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.pri-row:last-child {
  border-bottom: none;
}
.pri-label {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 500;
}
.pri-val {
  font-size: 24rpx;
  color: var(--purple-muted);
}

/* ===== 编辑表单弹窗 ===== */
.editor-box {
  background: #fff;
  border-radius: 24rpx;
  width: 600rpx;
  max-height: 80vh;
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
}
.editor-form {
  flex: 1;
  max-height: 50vh;
  margin-top: 20rpx;
}
.ef-row {
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
}
.ef-label {
  font-size: 24rpx;
  color: var(--purple-muted);
  margin-bottom: 6rpx;
  font-weight: 500;
}
.ef-input {
  width: 100%;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--border);
  font-size: 26rpx;
  background: var(--purple-bg);
  color: var(--text);
  box-sizing: border-box;
}
.ef-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--border);
  font-size: 26rpx;
  background: var(--purple-bg);
  color: var(--text);
  box-sizing: border-box;
}
.ef-hint {
  font-size: 22rpx;
  color: var(--purple-light);
  display: block;
  margin-top: 8rpx;
}

/* ===== noop helper ===== */
.noop {}
