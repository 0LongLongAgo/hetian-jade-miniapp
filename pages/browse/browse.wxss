.page-wrap { padding: 0 24rpx 40rpx; }

/* 分类标签 */
.browse-tabs {
  display: flex; white-space: nowrap;
  padding: 12rpx 0; margin-bottom: 16rpx;
}
.b-tab {
  display: inline-block; flex-shrink: 0;
  padding: 10rpx 28rpx; border-radius: 32rpx;
  font-size: 26rpx; color: #8B7A9B; margin-right: 10rpx;
  background: #fff; border: 1rpx solid #E8DFF0;
  transition: all 0.2s;
}
.b-tab.active {
  background: var(--gradient-btn); color: #fff;
  border-color: transparent;
}

/* 商品网格 */
.browse-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.b-card {
  background: #fff; border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(94,61,122,0.05);
  transition: all 0.2s;
}
.b-card:active { transform: scale(0.97); }
.bc-img-wrap {
  width: 100%; aspect-ratio: 1; display: flex;
  align-items: center; justify-content: center;
}
.bc-img { width: 100%; height: 100%; }
.bc-img-swatch {
  width: 100%; height: 100%; display: flex;
  align-items: center; justify-content: center;
}
.bc-size-tag {
  font-size: 36rpx; color: rgba(255,255,255,0.85);
  font-weight: 700;
}
.bc-name {
  font-size: 28rpx; font-weight: 600; color: #3D2E4E;
  display: block; padding: 0 16rpx;
  margin-top: 12rpx;
}
.bc-cat {
  font-size: 22rpx; color: #A898B8;
  display: block; padding: 0 16rpx;
  margin-top: 4rpx;
}
.bc-price {
  font-size: 28rpx; font-weight: 700; color: #E65100;
  display: block; padding: 0 16rpx;
  margin: 8rpx 0 16rpx;
}

/* CTA */
.browse-cta {
  margin-top: 32rpx; padding: 24rpx;
  background: var(--gradient-btn);
  border-radius: 20rpx; text-align: center;
  color: #fff; font-size: 30rpx; font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(94,61,122,0.2);
}
.browse-cta:active { opacity: 0.85; }
