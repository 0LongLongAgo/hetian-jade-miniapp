/* === 图片详情页 — 沉浸式大图浏览 === */

.page-root {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 160rpx;
}

/* ===== 骨架屏 ===== */
.skeleton-wrap {
  padding: 0 24rpx;
}
.skeleton-img {
  width: 100%; height: 480rpx;
  background: linear-gradient(90deg, #F6F2F9 0%, #EDE4F4 50%, #F6F2F9 100%);
  background-size: 200% 100%;
  border-radius: 0 0 24rpx 24rpx;
}
.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, #F6F2F9 0%, #EDE4F4 50%, #F6F2F9 100%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  margin-left: 24rpx;
}
.skeleton-card {
  height: 160rpx;
  margin: 16rpx 24rpx;
  background: linear-gradient(90deg, #F6F2F9 0%, #EDE4F4 50%, #F6F2F9 100%);
  background-size: 200% 100%;
  border-radius: 20rpx;
}

/* ===== 错误状态 ===== */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 40rpx;
}

/* ===== 大图展示区 ===== */
.hero-section {
  position: relative;
  width: 100%;
  min-height: 400rpx;
  max-height: 60vh;
  overflow: hidden;
  border-radius: 0 0 24rpx 24rpx;
  background: var(--bg);
  box-shadow: 0 8rpx 32rpx rgba(94,61,122,0.12);
}
.hero-image {
  width: 100%;
  max-height: 60vh;
  display: block;
}
.hero-placeholder {
  width: 100%;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.hero-emoji {
  font-size: 96rpx;
  opacity: 0.45;
}
.hero-hint {
  font-size: 22rpx;
  color: rgba(94,61,122,0.5);
  margin-top: 12rpx;
}
.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(to top, rgba(94,61,122,0.08), transparent);
}

/* ===== 名称行 ===== */
.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 24rpx 8rpx;
}
.item-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}
.cat-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: var(--purple-accent);
  color: #fff;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

/* ===== 信息卡片 ===== */
.info-card {
  margin: 16rpx 24rpx;
  background: var(--card);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(107,75,133,0.05);
}
.card-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}
.card-icon {
  font-size: 36rpx;
}
.card-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}
.card-text {
  font-size: 26rpx;
  color: var(--purple-dark);
  line-height: 1.8;
}
.text-muted-card {
  color: var(--purple-muted);
}

/* ===== 信息网格 (珠子/料子详情) ===== */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}
.info-grid-item {
  padding: 12rpx 16rpx;
  background: var(--purple-bg);
  border-radius: 12rpx;
}
.ig-label {
  font-size: 22rpx;
  color: var(--purple-muted);
  display: block;
  margin-bottom: 4rpx;
}
.ig-val {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 500;
  display: block;
}
.ig-val.price {
  color: #E65100;
  font-weight: 700;
}
.ig-color-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.ig-color-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0,0,0,0.08);
  flex-shrink: 0;
}

/* ===== 底部CTA ===== */
.bottom-cta {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, var(--bg) 30%);
  z-index: 10;
}
.cta-btn {
  width: 100%;
  height: 96rpx;
  background: var(--gradient-btn);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(123,91,149,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cta-btn::after {
  border: none;
}
